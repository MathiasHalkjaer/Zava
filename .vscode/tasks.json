{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Zava Solution",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"Zava.sln"
			],
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "Run Zava API",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"src/Zava.Api"
			],
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Run Zava Web",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"src/Zava.Web"
			],
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Run Zava Demo",
			"dependsOn": [
				"Run Zava API",
				"Run Zava Web"
			],
			"dependsOrder": "parallel",
			"problemMatcher": []
		}
	]
}